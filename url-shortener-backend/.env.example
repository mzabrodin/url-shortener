# Port numbers for the services
GATEWAY_PORT=8080
REDIRECT_PORT=8081
SHORTEN_PORT=8082
STATS_PORT=8083

# DB configuration
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=super_secure_password
DB_NAME=urlshortener
DB_SSL_MODE=disable

# Redis configuration
REDIS_HOST=redis
REDIS_PASSWORD=super_secure_password
REDIS_PORT=6379

# Logging level for pino
LOG_LEVEL=info

# Cache TTL in seconds (1 hour)
CACHE_TTL_SECONDS=3600

# TTL for negative cache entries, when a short code is not found (5 minutes)
NEGATIVE_CACHE_TTL_SECONDS=300

# API key for the stats endpoints
ADMIN_API_KEY=change_me

# Allowed CORS origin for the gateway
CLIENT_URL=http://localhost:8000
